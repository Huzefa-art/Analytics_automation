# ─── Backend Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
# For Render: set these in the Render dashboard → Environment tab.
# For local Docker: these go in your .env file at the project root.

# ── NVIDIA API (required for all AI analysis) ────────────────────────────────
# Get from: https://build.nvidia.com → Sign in → Get API Key
nvidia_api_key=nvapi-YOUR_KEY_HERE

# ── SerpAPI (required for Google search scraping in Pain Points tab) ─────────
# Get from: https://serpapi.com → Dashboard → API Key  (free: 100 searches/month)
serp_api=YOUR_SERPAPI_KEY_HERE

# ── Slack integration (optional — for sending leads to Slack) ────────────────
# Webhook: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# Bot token: https://api.slack.com/apps → your app → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-YOUR-BOT-TOKEN
SLACK_CHANNEL=ai-analytics

# ── Ngrok (local tunnel only — not needed on Render) ─────────────────────────
# Get from: https://dashboard.ngrok.com/auth
NGROK_AUTHTOKEN=YOUR_NGROK_TOKEN

# ── Database path (auto-set by render.yaml — leave as default locally) ───────
# DB_PATH=/app/data/leads.db  # Render sets this automatically via render.yaml
