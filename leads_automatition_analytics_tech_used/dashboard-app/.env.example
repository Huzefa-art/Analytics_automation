# ─── Frontend Environment Variables ─────────────────────────────────────────
# Copy this file to dashboard-app/.env and fill in your values.
# For Vercel: set these in Vercel dashboard → Settings → Environment Variables.
# The VITE_ prefix is REQUIRED for Vite to expose vars to the browser.

# ── Backend API URL ───────────────────────────────────────────────────────────
# Local dev: leave empty (uses vite proxy to localhost:8000)
# Vercel production: set to your Render backend URL
# Example: VITE_API_URL=https://antigravity-analytics-api.onrender.com
VITE_API_URL=
