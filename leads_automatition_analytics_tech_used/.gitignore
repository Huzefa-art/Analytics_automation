# Virtual Environment
venv/
.venv/
env/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Workspace settings
.vscode/
.idea/

# Local data / Output files
results.csv
urls.txt
urls_to_analyze.txt
*.xlsx

# SQLite database (local only — Render uses persistent disk)
leads.db

# Sensitive information
service_account.json

# OS files
.DS_Store
Thumbs.db

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build outputs — DO NOT gitignore dist/ 
# Vercel builds from source, Render doesn't need it
# dist/ is kept out of git — Vercel builds it automatically
dist/
build/
.cache/
.parcel-cache/

# Environment variables (never commit real .env)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
